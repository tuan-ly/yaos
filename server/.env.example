# Optional override for local dev / automation.
# If omitted, the server starts unclaimed and can be claimed in a browser.
SYNC_TOKEN=replace-with-a-random-shared-secret
YAOS_TEST_HOST=http://127.0.0.1:8787

# Local development:
#   npm --prefix server run dev -- --var SYNC_TOKEN:$SYNC_TOKEN
#
# Attachments and snapshots stay disabled until you add an R2 binding
# named YAOS_BUCKET in the Cloudflare dashboard.
